# ─── BREAKERS ───────────────────────────────────────────────────
cmd_breakers() {
    check_runtime
    echo -e "${BOLD}Circuit Breakers${NC}"
    echo ""

    curl -sf "$(admin_url)/admin/breakers" | python3 -c "
import json, sys
d = json.load(sys.stdin)
if not d:
    print('  No circuit breakers active.')
else:
    for name, b in d.items():
        state = b['state']
        color = '\033[32m' if state == 'CLOSED' else '\033[31m' if state == 'OPEN' else '\033[33m'
        print(f'  {name}:')
        print(f'    State:     {color}{state}\033[0m')
        print(f'    Success:   {b[\"successfulCalls\"]}')
        print(f'    Failed:    {b[\"failedCalls\"]}')
        print(f'    Rejected:  {b[\"notPermittedCalls\"]}')
        print()
" 2>/dev/null
}

# ─── TOP ────────────────────────────────────────────────────────
cmd_top() {
    check_runtime
    echo -e "${BOLD}KubeFn Live Dashboard (Ctrl+C to exit)${NC}"
    echo ""

    while true; do
        clear
        banner
        echo ""
        cmd_status
        echo ""
        cmd_heap
        echo ""
        cmd_breakers
        sleep 2
    done
}

# ─── TRACE (Heap Trace) ──────────────────────────────────────────
cmd_trace() {
    check_runtime
    local filter="${1:-}"
    local filter_type="${2:-}"

    if [[ -z "$filter" ]]; then
        echo -e "${BOLD}Heap Trace — recent operations${NC}"
        echo ""
        curl -sf "$(admin_url)/admin/heap/trace?limit=30" | python3 -c "
import json, sys
data = json.load(sys.stdin)
entries = data.get('entries', [])
if not entries:
    print('  No trace entries yet. Make some requests first.')
    sys.exit(0)
print(f'  {len(entries)} entries (of {data[\"trace\"][\"totalEntries\"]} total)')
print()
print(f'  {\"TIME\":<28} {\"OP\":<10} {\"KEY\":<25} {\"FUNCTION\":<25} {\"V\":>5}')
print(f'  {\"─\"*28} {\"─\"*10} {\"─\"*25} {\"─\"*25} {\"─\"*5}')
for e in entries:
    t = e.get('time','')[:23]
    op = e.get('op','')
    key = e.get('key','')[:24]
    fn = f\"{e.get('group','')}.{e.get('function','')}\"[:24]
    v = e.get('version', 0)
    color = '\033[32m' if 'PUBLISH' in op else '\033[36m' if 'HIT' in op else '\033[33m' if 'MISS' in op else '\033[31m'
    print(f'  {t:<28} {color}{op:<10}\033[0m {key:<25} {fn:<25} {v:>5}')
" 2>/dev/null || echo -e "${RED}Failed to fetch trace${NC}"
        echo ""
        echo -e "${CYAN}Usage:${NC}"
        echo "  kubefn trace                     Recent heap operations"
        echo "  kubefn trace --key pricing:current  History for a key"
        echo "  kubefn trace --request <id>      Ops for a request"
        echo "  kubefn trace --function TaxFn     Ops by a function"
        return
    fi

    local url_param=""
    case "$filter" in
        --key)      url_param="key=$filter_type" ;;
        --request)  url_param="request=$filter_type" ;;
        --function) url_param="function=$filter_type" ;;
        *)          url_param="request=$filter" ;;  # default: treat as request ID
    esac

    echo -e "${BOLD}Heap Trace — filtered by ${CYAN}${filter} ${filter_type:-$filter}${NC}"
    echo ""
    curl -sf "$(admin_url)/admin/heap/trace?${url_param}" | python3 -c "
import json, sys
data = json.load(sys.stdin)
entries = data.get('entries', [])
if not entries:
    print('  No matching entries.')
    sys.exit(0)
print(f'  {len(entries)} entries')
print()
print(f'  {\"TIME\":<28} {\"OP\":<10} {\"KEY\":<25} {\"FUNCTION\":<25} {\"V\":>5}')
print(f'  {\"─\"*28} {\"─\"*10} {\"─\"*25} {\"─\"*25} {\"─\"*5}')
for e in entries:
    t = e.get('time','')[:23]
    op = e.get('op','')
    key = e.get('key','')[:24]
    fn = f\"{e.get('group','')}.{e.get('function','')}\"[:24]
    v = e.get('version', 0)
    color = '\033[32m' if 'PUBLISH' in op else '\033[36m' if 'HIT' in op else '\033[33m' if 'MISS' in op else '\033[31m'
    print(f'  {t:<28} {color}{op:<10}\033[0m {key:<25} {fn:<25} {v:>5}')
" 2>/dev/null || echo -e "${RED}Failed to fetch trace${NC}"
}

# ─── GRAPH ─────────────────────────────────────────────────────
cmd_graph() {
    check_runtime
    local fn="${1:-}"

    if [[ -n "$fn" ]]; then
        echo -e "${BOLD}Impact Analysis: ${CYAN}${fn}${NC}"
        echo ""
        curl -sf "$(admin_url)/admin/heap/graph?function=${fn}" | python3 -c "
import json, sys
data = json.load(sys.stdin)
pub = data.get('publishesKeys', [])
reads = data.get('readsKeys', [])
down = data.get('downstreamFunctions', [])
up = data.get('upstreamFunctions', [])
affected = data.get('affectedConsumers', {})

print(f'  Publishes: {', '.join(pub) if pub else 'none'}')
print(f'  Reads:     {', '.join(reads) if reads else 'none'}')
print(f'  Upstream:  {', '.join(up) if up else 'none'}')
print(f'  Downstream: {', '.join(down) if down else 'none'} ({len(down)} affected)')
print()
if affected:
    print('  Affected consumers:')
    for key, cons in affected.items():
        for c in cons:
            print(f'    {key} → {c}')
" 2>/dev/null || echo -e "${RED}Failed to fetch graph${NC}"
    else
        echo -e "${BOLD}Heap Dependency Graph${NC}"
        echo ""
        curl -sf "$(admin_url)/admin/heap/graph/ascii" 2>/dev/null || \
            echo -e "${RED}Failed to fetch graph. Is the runtime running?${NC}"
        echo ""
        echo -e "${CYAN}Usage:${NC}"
        echo "  kubefn graph                    Full dependency DAG"
        echo "  kubefn graph checkout.PricingFn  Impact analysis for a function"
    fi
}

# ─── LOGS ───────────────────────────────────────────────────────
cmd_logs() {
    echo -e "${BOLD}Streaming logs from K8s namespace: ${CYAN}${NAMESPACE}${NC}"
    kubectl logs -n "${NAMESPACE}" -l app.kubernetes.io/name=kubefn-runtime -f --tail=50
}

# ─── VERSION ────────────────────────────────────────────────────
cmd_version() {
    echo "kubefn v${VERSION}"
}

# ─── MAIN ───────────────────────────────────────────────────────
case "${1:-}" in
    init)       shift; cmd_init "$@" ;;
    dev)        shift; cmd_dev "$@" ;;
    deploy)     shift; cmd_deploy "$@" ;;
    functions)  cmd_functions ;;
    status)     cmd_status ;;
    heap)       cmd_heap ;;
    breakers)   cmd_breakers ;;
    top)        cmd_top ;;
    trace)      shift; cmd_trace "$@" ;;
    graph)      shift; cmd_graph "$@" ;;
    logs)       cmd_logs ;;
    version)    cmd_version ;;
    -v|--version) cmd_version ;;
    -h|--help|"") usage ;;
    *)
        echo -e "${RED}Unknown command: ${1}${NC}"
        echo "Run 'kubefn --help' for usage."
        exit 1
        ;;
esac
