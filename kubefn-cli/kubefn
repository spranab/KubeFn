package ${package}.functions;

import com.kubefn.api.*;
import ${package}.contracts.HeapKeys;
import ${package}.contracts.OrderResult;

import java.util.Map;
import java.util.UUID;

/**
 * Sample KubeFn function demonstrating HeapExchange patterns.
 *
 * <p>This function:
 * <ol>
 *   <li>Reads an optional OrderResult from heap (if a previous step published one)</li>
 *   <li>Creates and publishes a new OrderResult to heap</li>
 *   <li>Returns a response to the HTTP caller</li>
 * </ol>
 *
 * <p>Other functions in this group can read the published OrderResult
 * with zero-copy, zero-serialization via:
 * <pre>{@code
 * OrderResult order = ctx.heap().require(HeapKeys.ORDER);
 * }</pre>
 */
@FnRoute(path = "/hello", methods = {"GET", "POST"})
@FnGroup("${name}")
public class HelloFunction implements KubeFnHandler, FnContextAware {

    private FnContext ctx;

    @Override
    public void setContext(FnContext context) {
        this.ctx = context;
    }

    @Override
    public KubeFnResponse handle(KubeFnRequest request) throws Exception {
        HeapExchange heap = ctx.heap();

        // Read from heap — check if a previous function published an order
        var existing = heap.get(HeapKeys.ORDER);

        String name = request.queryParam("name").orElse("World");
        String orderId = "ORD-" + UUID.randomUUID().toString().substring(0, 8);

        // Create a typed contract object
        OrderResult order = new OrderResult(
            orderId,
            "created",
            42.00,
            "Hello, " + name + "!"
        );

        // Publish to heap — siblings receive the SAME Java reference (zero-copy)
        heap.publish(HeapKeys.ORDER, order);

        ctx.logger().info("HelloFunction: published OrderResult orderId={}", orderId);

        return KubeFnResponse.ok(Map.of(
            "orderId", order.orderId(),
            "status", order.status(),
            "total", order.total(),
            "message", order.message(),
            "previousOrderExists", existing.isPresent()
        ));
    }
}
HELLO

    # ── CLAUDE.md ──
    cat > "${dir}/CLAUDE.md" << 'CLAUDEMD'
# KubeFn Function Development Rules

## What is this project
A KubeFn function project. Functions share a JVM heap via HeapExchange — zero-copy, zero-serialization object sharing between independently deployed functions.

## Project Structure
```
contracts/    → Shared type definitions + HeapKey constants
functions/    → Individual function modules (each becomes a thin JAR)
```

## Critical Rules
1. **NEVER serialize/deserialize heap objects** — they are shared references, not messages
2. **ALWAYS use contract types** from the contracts module — never raw Map
3. **ALWAYS use HeapKeys constants** — never hardcode key strings
4. **ALWAYS handle Optional.empty()** — the producer might not have run yet
5. **NEVER mutate objects read from heap** — treat them as immutable (use records)
6. **Functions are stateless** — all shared state goes through HeapExchange

## HeapExchange API
```java
ctx.heap().publish(HeapKeys.ORDER, orderResult);         // Publish (zero-copy)
ctx.heap().require(HeapKeys.ORDER);                       // Read or throw
ctx.heap().get(HeapKeys.ORDER);                           // Read → Optional<T>
ctx.heap().getOrDefault(HeapKeys.ORDER, fallback);        // Read with default
ctx.heap().contains(HeapKeys.ORDER);                      // Check existence
ctx.heap().remove(HeapKeys.ORDER);                        // Remove
ctx.heap().keys();                                        // List all keys
```

## How to Create a Function

### 1. Define contracts (contracts module)
```java
// Contract type — always use records for immutability
public record OrderResult(String orderId, String status, double total) {}

// HeapKey — typed, compile-time safe
public static final HeapKey<OrderResult> ORDER = HeapKey.of("order:result", OrderResult.class);
```

### 2. Implement the function
```java
@FnRoute(path = "/my/endpoint", methods = {"GET", "POST"})
@FnGroup("my-service")
public class MyFunction implements KubeFnHandler, FnContextAware {
    private FnContext ctx;

    @Override
    public void setContext(FnContext context) { this.ctx = context; }

    @Override
    public KubeFnResponse handle(KubeFnRequest request) throws Exception {
        // Read from heap (zero-copy)
        OrderResult order = ctx.heap().require(HeapKeys.ORDER);

        // Publish to heap (zero-copy)
        ctx.heap().publish(HeapKeys.ORDER, newOrder);

        return KubeFnResponse.ok(Map.of("result", "done"));
    }
}
```

### 3. Test with kubefn-testing
```java
@Test
void publishesOrder() {
    var heap = FakeHeapExchange.create();
    var ctx = FakeFnContext.of(heap);
    var fn = new MyFunction();
    fn.setContext(ctx);

    fn.handle(TestRequest.empty());

    OrderResult order = heap.require(HeapKeys.ORDER);
    assertEquals("created", order.status());
}
```

## Dependencies (layered classpath)
```gradle
compileOnly("com.kubefn:kubefn-api:0.4.0")        // Layer 1: interfaces
compileOnly(project(":contracts"))                  // Layer 2: your contracts
testImplementation("com.kubefn:kubefn-testing:0.4.0") // Testing fakes
```

## Commands
```bash
kubefn dev        # Local dev with hot-reload
kubefn deploy     # Deploy to runtime
kubefn heap       # Inspect HeapExchange
kubefn functions  # List deployed functions
kubefn status     # Runtime status
```
