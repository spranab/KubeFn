package ${package}.contracts;

import com.kubefn.api.HeapKey;

/**
 * Central registry of all HeapExchange keys for this project.
 *
 * <p>Every heap key used across functions is defined here as a typed {@link HeapKey}.
 * This eliminates string typos AND type mismatches at compile time.
 *
 * <h3>Usage:</h3>
 * <pre>{@code
 * // Read — compile-time safe
 * OrderResult order = ctx.heap().require(HeapKeys.ORDER);
 *
 * // Write — type-checked
 * ctx.heap().publish(HeapKeys.ORDER, orderResult);
 * }</pre>
 */
public final class HeapKeys {

    private HeapKeys() {}

    /** Order result. Published by order processing functions. */
    public static final HeapKey<OrderResult> ORDER =
            HeapKey.of("order:result", OrderResult.class);
}
HEAPKEYS

    # ── OrderResult.java ──
    cat > "${dir}/contracts/src/main/java/${pkg_path}/contracts/OrderResult.java" << ORDERRESULT
package ${package}.contracts;

/**
 * Sample contract type representing an order result.
 *
 * <p>Contract types are shared between functions via HeapExchange.
 * Use Java records for immutability — once published, data cannot
 * be accidentally mutated by a consumer.
 *
 * <p>Heap key: {@code order:result} (see {@link HeapKeys#ORDER})
 */
public record OrderResult(
        String orderId,
        String status,
        double total,
        String message
) {}
ORDERRESULT

