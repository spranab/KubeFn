    echo -e "${BOLD}KubeFn Runtime Status${NC}"
    echo ""

    curl -sf "$(admin_url)/admin/status" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(f'  Version:     v{d[\"version\"]}')
print(f'  Uptime:      {d[\"uptime_ms\"] // 1000}s')
print(f'  Routes:      {d[\"route_count\"]}')
print(f'  Heap:        {d[\"heap_used_mb\"]}MB / {d[\"heap_max_mb\"]}MB')
print(f'  Threads:     {d[\"thread_count\"]}')
print(f'  Classes:     {d[\"loaded_classes\"]}')
print(f'  JVM:         {d[\"jvm_version\"]}')
" 2>/dev/null
}

# ─── HEAP ───────────────────────────────────────────────────────
cmd_heap() {
    check_runtime
    echo -e "${BOLD}HeapExchange — Shared Object Graph${NC}"
    echo ""

    curl -sf "$(admin_url)/admin/heap" | python3 -c "
import json, sys
d = json.load(sys.stdin)
print(f'  Objects:     {d[\"objectCount\"]}')
print(f'  Publishes:   {d[\"publishCount\"]}')
